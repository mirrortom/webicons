// tai chi 太极图案

.i-fv-taichi
    border-radius: 50%
    border: 1px solid currentColor
    background-image: linear-gradient(90deg,black 50%,white 50%, white 100%)
    &:before, &:after
        width: .5em
        height: .5em
        border-radius: 50%
        border-style: solid
        border-width: .165em

    &:before
        border-color: white
        background-color: black

    &:after
        border-color: black
        background-color: white